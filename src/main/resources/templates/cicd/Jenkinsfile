pipeline {
    agent any

    environment {
        SERVICE_NAME = "{{service_name}}"
        REPO_URL = "{{repo_url}}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Cloning ${REPO_URL}"
            }
        }

        stage('Build') {
            steps {
                echo "Building ${SERVICE_NAME}"
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker image"
            }
        }

        stage('Push to ECR') {
            steps {
                echo "Pushing image to ECR"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying to Kubernetes"
            }
        }
    }
}